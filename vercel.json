{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "installCommand": "npm install && cd server && npm install",
  "functions": {
    "api/[...path].ts": {
      "includeFiles": "server/src/**/*.ts",
      "maxDuration": 10
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/[...path]" },
    { "source": "/docs/(.*)", "destination": "/api/[...path]" },
    { "source": "/docs", "destination": "/api/[...path]" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
